<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Pluxy" parent="Theme.AppCompat.NoActionBar">
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/bg</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>

    <!-- ===================== Typographie ===================== -->
    <!-- Base implicite des styles Text.* (requise par la notation pointée). -->
    <style name="Text" />

    <style name="Text.Display">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="Text.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Heading">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Text.Body">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="Text.Caption">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- ===================== Boutons ===================== -->
    <style name="Btn">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/btn_min_h</item>
        <item name="android:minWidth">128dp</item>
        <item name="android:paddingHorizontal">26dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:focusable">true</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:stateListAnimator">@animator/focus_lift_btn</item>
    </style>

    <style name="Btn.Primary" parent="Btn">
        <item name="android:background">@drawable/bg_btn_primary</item>
        <item name="android:textColor">@color/text_on_accent</item>
    </style>

    <style name="Btn.Secondary" parent="Btn">
        <item name="android:background">@drawable/bg_btn_secondary</item>
        <item name="android:textColor">@color/btn_secondary_text</item>
    </style>

    <style name="Btn.Icon" parent="Btn">
        <item name="android:layout_width">@dimen/icon_btn</item>
        <item name="android:layout_height">@dimen/icon_btn</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingHorizontal">0dp</item>
        <item name="android:background">@drawable/bg_btn_icon</item>
        <item name="android:textColor">@color/btn_secondary_text</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Conservé pour compatibilité (bouton ⚙ du lecteur). -->
    <style name="PluxyPlayerBtn" parent="Btn.Icon" />
</resources>
