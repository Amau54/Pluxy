<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0f14"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/pluxy_logo"
            android:contentDescription="Pluxy" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pluxy"
            android:textColor="#e5a00d"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/serverLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:textColor="#8a93a6"
            android:textSize="13sp" />

        <Button
            android:id="@+id/reload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="↻ Actualiser"
            android:textColor="#1a1205"
            android:textSize="12sp"
            android:backgroundTint="#e5a00d" />

        <Button
            android:id="@+id/settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="⚙ Réglages"
            android:textColor="#e7eaf0"
            android:textSize="12sp"
            android:backgroundTint="#2a3142" />

        <Button
            android:id="@+id/changeServer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Serveur"
            android:textColor="#e7eaf0"
            android:textSize="12sp"
            android:backgroundTint="#2a3142" />
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="64dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/grid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#8a93a6"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/emptyAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="🔎  Rechercher un serveur"
            android:textColor="#1a1205"
            android:backgroundTint="#e5a00d"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
