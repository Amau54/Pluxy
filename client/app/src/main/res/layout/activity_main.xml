<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:paddingHorizontal="@dimen/screen_pad"
    android:paddingTop="28dp"
    android:paddingBottom="20dp">

    <!-- Barre de titre : logo + « Pluxy » (gauche, fixe) · serveur (centre, extensible)
         · boutons icône (droite, largeur constante). -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/pluxy_logo"
                android:contentDescription="Pluxy" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pluxy"
                android:textColor="@color/accent"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />
        </LinearLayout>

        <TextView
            android:id="@+id/serverLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:drawablePadding="6dp"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <Button
            android:id="@+id/reload"
            style="@style/Btn.Icon"
            android:layout_marginEnd="10dp"
            android:text="↻"
            android:contentDescription="Actualiser" />

        <Button
            android:id="@+id/settings"
            style="@style/Btn.Icon"
            android:layout_marginEnd="10dp"
            android:text="⚙"
            android:contentDescription="Réglages" />

        <Button
            android:id="@+id/changeServer"
            style="@style/Btn.Icon"
            android:text="⇄"
            android:contentDescription="Changer de serveur" />
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/grid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingTop="6dp"
            android:paddingBottom="24dp" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/emptyAction"
            style="@style/Btn.Primary"
            android:layout_marginTop="20dp"
            android:text="🔎  Rechercher un serveur"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
