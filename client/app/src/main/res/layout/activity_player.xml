<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:surface_type="surface_view"
        app:use_controller="true"
        app:show_subtitle_button="false" />

    <!-- Roue crantée unique : audio / sous-titres / vitesse / format / instant /
         réglages avancés / infos & logs -->
    <Button
        android:id="@+id/btnGear"
        style="@style/Btn.Icon"
        android:layout_gravity="top|end"
        android:layout_margin="24dp"
        android:text="⚙" />

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="24dp"
        android:background="@drawable/bg_pill_dark"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:textColor="@color/info"
        android:textSize="14sp" />

    <!-- Overlay seek progressif : direction · delta · position cible -->
    <LinearLayout
        android:id="@+id/seekOverlay"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_seek_overlay"
        android:elevation="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="26dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/seekArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/seekDelta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/accent"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/seekTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/text_tertiary"
            android:textSize="17sp"
            android:letterSpacing="0.02" />
    </LinearLayout>
</FrameLayout>
