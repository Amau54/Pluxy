<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ImageView
        android:id="@+id/backdrop"
        android:layout_width="match_parent"
        android:layout_height="540dp"
        android:scaleType="centerCrop"
        android:alpha="0.45"
        android:contentDescription="Backdrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="540dp"
        android:background="@drawable/scrim_backdrop" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_pad"
            android:paddingTop="56dp"
            android:paddingBottom="44dp">

            <!-- En-tête : affiche + infos + actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/poster"
                    android:layout_width="196dp"
                    android:layout_height="294dp"
                    android:background="@drawable/poster_rounded"
                    android:clipToOutline="true"
                    android:elevation="12dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Affiche" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title"
                        style="@style/Text.Display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:letterSpacing="0.01" />

                    <!-- Pastilles techniques (résolution, codec, HDR) renseignées en code -->
                    <LinearLayout
                        android:id="@+id/chips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal" />

                    <TextView
                        android:id="@+id/tagline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="italic"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/director"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/play"
                            style="@style/Btn.Primary"
                            android:text="▶  Lire" />

                        <Button
                            android:id="@+id/trailer"
                            style="@style/Btn.Secondary"
                            android:layout_marginStart="14dp"
                            android:text="🎬  Bande-annonce" />

                        <Button
                            android:id="@+id/playSettings"
                            style="@style/Btn.Secondary"
                            android:layout_marginStart="14dp"
                            android:text="⚙  Réglages" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/overviewLabel"
                style="@style/Text.Heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:text="SYNOPSIS" />

            <TextView
                android:id="@+id/overview"
                style="@style/Text.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#E1E6EF" />

            <TextView
                style="@style/Text.Heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="DISTRIBUTION" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingBottom="12dp"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/status"
                style="@style/Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
