<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="80dp"
        android:paddingVertical="56dp">

        <ImageView
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:src="@drawable/pluxy_logo"
            android:adjustViewBounds="true"
            android:contentDescription="Pluxy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Connexion au serveur Pluxy"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:text="Recherche du serveur sur le réseau…"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:indeterminateTint="@color/accent" />

        <!-- Liste des serveurs découverts -->
        <LinearLayout
            android:id="@+id/serverList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_horizontal"
            android:orientation="vertical" />

        <Button
            android:id="@+id/rescan"
            style="@style/Btn.Secondary"
            android:layout_marginTop="18dp"
            android:text="↻  Rechercher à nouveau" />

        <!-- Saisie manuelle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="…ou saisir l'adresse manuellement"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp"
            android:letterSpacing="0.02" />

        <EditText
            android:id="@+id/manualIp"
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="192.168.1.70  (ou 192.168.1.70:8420)"
            android:textColorHint="@color/text_tertiary"
            android:inputType="text"
            android:minHeight="@dimen/btn_min_h"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/connectManual"
            style="@style/Btn.Primary"
            android:layout_marginTop="14dp"
            android:text="Se connecter" />
    </LinearLayout>
</ScrollView>
