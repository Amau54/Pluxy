<?xml version="1.0" encoding="utf-8"?>
<!-- Champ de saisie : liseré or au focus pour une cible claire à la télécommande. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <stroke android:width="2dp" android:color="@color/accent" />
            <corners android:radius="@dimen/radius_sm" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <stroke android:width="1dp" android:color="@color/border" />
            <corners android:radius="@dimen/radius_sm" />
        </shape>
    </item>
</selector>
