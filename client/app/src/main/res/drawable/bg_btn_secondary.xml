<?xml version="1.0" encoding="utf-8"?>
<!-- Bouton secondaire (surface). Au focus : remplissage or + texte sombre (inversion). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent" />
            <stroke android:width="2dp" android:color="#FFFFFFFF" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_focus" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_variant" />
            <stroke android:width="1dp" android:color="@color/border" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
</selector>
