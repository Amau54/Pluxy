<?xml version="1.0" encoding="utf-8"?>
<!-- Fond de carte focalisable : anneau or épais + surface éclaircie au focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_focus" />
            <stroke android:width="@dimen/focus_stroke" android:color="@color/border_focus" />
            <corners android:radius="@dimen/radius_md" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <stroke android:width="1dp" android:color="@color/border_subtle" />
            <corners android:radius="@dimen/radius_md" />
        </shape>
    </item>
</selector>
